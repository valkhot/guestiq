# .env.example
# GuestIQ — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and is NEVER committed to Git.
# GitHub Actions injects these from GitHub Secrets at build time.

# ── Supabase ────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://[your-project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...   # anon/public key ONLY — NOT service_role key

# ── Sentry ──────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=https://[key]@[org].ingest.sentry.io/[project-id]

# ── PostHog ─────────────────────────────────────────────────────────────────
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Application ─────────────────────────────────────────────────────────────
VITE_APP_ENV=development        # 'development' | 'pilot' | 'production'
VITE_APP_VERSION=1.0.0

# ── Feature Flags — all false in Phase 1 ───────────────────────────────────
VITE_FEATURE_AUTH_ENABLED=false
VITE_FEATURE_MULTI_PROPERTY=false
VITE_FEATURE_ADMIN_ENABLED=false
